#!/usr/bin/env bash
# fbrain post-commit hook: preserve Git LFS behavior and run optional indexer.

set -euo pipefail

FBRAIN_ROOT="${FBRAIN_ROOT:-${ICONTEXT_ROOT:-$HOME/fbrain}}"

if command -v git-lfs >/dev/null 2>&1; then
    git lfs post-commit "$@"
fi

if [ -x "$FBRAIN_ROOT/scripts/update_index.py" ]; then
    "$FBRAIN_ROOT/scripts/update_index.py" --repo "$PWD" || {
        echo "fbrain: semantic index update failed; commit kept" >&2
        exit 0
    }
fi

