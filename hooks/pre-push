#!/usr/bin/env bash
# fbrain pre-push hook: preserve Git LFS behavior, then enforce tier placement.

set -euo pipefail

FBRAIN_ROOT="${FBRAIN_ROOT:-${ICONTEXT_ROOT:-$HOME/fbrain}}"
CONFIG="${FBRAIN_TIERS_CONFIG:-${ICONTEXT_TIERS_CONFIG:-.icontext-tiers.yml}}"

REMOTE_NAME="${1:-}"
REMOTE_URL="${2:-}"
STDIN_PAYLOAD="$(cat || true)"

if command -v git-lfs >/dev/null 2>&1; then
    if [ -n "$STDIN_PAYLOAD" ]; then
        printf "%s\n" "$STDIN_PAYLOAD" | git lfs pre-push "$REMOTE_NAME" "$REMOTE_URL"
    else
        git lfs pre-push "$REMOTE_NAME" "$REMOTE_URL" </dev/null
    fi
fi

if [ ! -f "$CONFIG" ]; then
    echo "fbrain: $CONFIG not found; skipping sensitivity tier check"
    exit 0
fi

args=()
while read -r local_ref local_sha remote_ref remote_sha; do
    [ -n "${local_ref:-}" ] || continue
    args+=(--ref-pair "$local_sha..$remote_sha")
done <<<"$STDIN_PAYLOAD"

PYTHONDONTWRITEBYTECODE=1 python3 "$FBRAIN_ROOT/scripts/check_tiers.py" --repo "$PWD" --config "$CONFIG" "${args[@]}"
